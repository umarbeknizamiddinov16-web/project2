// 1. В Prisma 7 здесь указывается только провайдер!
datasource db {
  provider = "postgresql"
}

// 2. Блок генератора клиента
generator client {
  provider = "prisma-client-js"
}

// 3. Таблица пользователя (синхронизация с Clerk)
model User {
  id        String   @id
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  boards    Board[]
}

// 4. Таблица досок задач
model Board {
  id        String   @id @default(uuid())
  title     String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks     Task[]
  createdAt DateTime @default(now())
}

// 5. Таблица карточек/задач
model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   
  boardId     String
  board       Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}
